# ─── Authentification ────────────────────────────────────────────────────────
# Clé secrète pour signer les JWT. OBLIGATOIRE en production.
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# Durée de validité des tokens JWT (format: https://github.com/vercel/ms)
JWT_EXPIRES_IN=7d

# ─── SQLite (utilisé si MYSQL_HOST n'est pas défini) ────────────────────────
# Chemin du fichier de base SQLite.
# Valeur par défaut : /etc/todos/todo.db (nécessite les droits d'écriture)
SQLITE_DB_LOCATION=./todo.db

# Si MYSQL_HOST est défini, l'application utilise MySQL à la place de SQLite.
# Architecture database-per-service : en compose/k8s, auth pointe sur auth-mysql
# et le backend (task) sur task-mysql. Ces hôtes sont définis par service, pas ici.
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# ─── Cache Redis (optionnel) ─────────────────────────────────────────────────
# Si REDIS_HOST est défini, le service active le cache-aside. Sinon, no-op
# (lecture directe en base). Défini par service en compose/k8s (auth-redis / task-redis).
REDIS_HOST=
REDIS_PORT=6379
CACHE_TTL_SECONDS=60

# ─── Message bus Kafka (optionnel) ───────────────────────────────────────────
# Si KAFKA_BROKERS est défini, auth publie les events (user.deleted) et le
# backend (task) les consomme. Sinon, no-op. Ex. compose/k8s : kafka:9092
KAFKA_BROKERS=

# Alternatives via fichiers (Docker secrets) — prioritaires sur les valeurs ci-dessus
MYSQL_HOST_FILE=
MYSQL_USER_FILE=
MYSQL_PASSWORD_FILE=
MYSQL_DB_FILE=
