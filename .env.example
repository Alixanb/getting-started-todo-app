# ─── Authentification ────────────────────────────────────────────────────────
# Clé secrète pour signer les JWT. OBLIGATOIRE en production.
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production

# Durée de validité des tokens JWT (format: https://github.com/vercel/ms)
JWT_EXPIRES_IN=7d

# ─── SQLite (utilisé si MYSQL_HOST n'est pas défini) ────────────────────────
# Chemin du fichier de base SQLite.
# Valeur par défaut : /etc/todos/todo.db (nécessite les droits d'écriture)
SQLITE_DB_LOCATION=./todo.db

# Si MYSQL_HOST est défini, l'application utilise MySQL à la place de SQLite.
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

# Alternatives via fichiers (Docker secrets) — prioritaires sur les valeurs ci-dessus
MYSQL_HOST_FILE=
MYSQL_USER_FILE=
MYSQL_PASSWORD_FILE=
MYSQL_DB_FILE=
